# Supabase configuration for Foovii menu data
# Replace these placeholder values with your actual Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=menu-assets
DATABASE_URL=postgresql://postgres:your-db-password@your-project-url.supabase.co:5432/postgres
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
